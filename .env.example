NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:3000
MONGODB_URI=mongodb://127.0.0.1:27017/routemuse
JSON_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Use a different high-entropy value in every deployed environment.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN_SECONDS=604800
BCRYPT_ROUNDS=12

# OAuth 2.0 client ID for the browser application, not the client secret.
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Dedicated database used only by npm run test:auth.
TEST_MONGODB_URI=mongodb://127.0.0.1:27017/routemuse_test

# Local demo seed credentials. Never reuse these in production.
DEMO_USER_NAME=RouteMuse Demo
DEMO_USER_EMAIL=demo@routemuse.local
DEMO_USER_PASSWORD=replace-with-a-strong-demo-password
